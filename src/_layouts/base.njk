<!DOCTYPE html>
<html lang="{{ lang | default('de') }}">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="description" content="{{ description }}">
<meta name="theme-color" content="#0d1b2a">
<meta name="robots" content="noindex,nofollow">
<meta property="og:title" content="{{ og_title | default(title) }}">
<meta property="og:description" content="{{ og_description | default(description) }}">
<meta property="og:type" content="website">
<meta property="og:url" content="https://zoebarossi.statichost.page{{ page.url }}">
<meta property="og:image" content="https://zoebarossi.statichost.page/images/og.jpg">
<meta name="twitter:card" content="summary_large_image">
<title>{{ title }}</title>
<link rel="icon" type="image/x-icon" href="{{ '/favicon.ico' | url }}">
<link rel="icon" type="image/png" sizes="32x32" href="{{ '/favicon-32.png' | url }}">
<link rel="icon" type="image/png" sizes="16x16" href="{{ '/favicon-16.png' | url }}">
<link rel="apple-touch-icon" sizes="180x180" href="{{ '/apple-touch-icon.png' | url }}">
<link rel="preload" href="{{ '/fonts/Inter.var.woff2' | url }}" as="font" type="font/woff2" crossorigin>
<link rel="stylesheet" href="{{ '/css/style.css' | url }}">
{% block head %}{% endblock %}
</head>
<body>

<nav class="nav">
  <div class="nav-inner">
    <a href="{{ nav_home | default('/') }}" class="nav-brand">zoe barossi</a>
    <div class="nav-links">
      <a href="{{ nav_about }}"{% if nav_active == 'about' %} style="color: var(--color-light); opacity: 1"{% endif %}>{{ t_about | default('Über') }}</a>
      <a href="{{ nav_partner }}"{% if nav_active == 'partner' %} style="color: var(--color-light); opacity: 1"{% endif %}>{{ t_partner | default('Partner') }}</a>
      <a href="{{ nav_live }}"{% if nav_active == 'live' %} style="color: var(--color-light); opacity: 1"{% endif %}>{{ t_live | default('Live') }}</a>
    </div>
    <div class="nav-lang">
      <a href="{{ lang_de }}"{% if lang == 'de' %} class="active"{% endif %}>DE</a>
      <a href="{{ lang_en }}"{% if lang == 'en' %} class="active"{% endif %}>EN</a>
      <a href="{{ lang_pt }}"{% if lang == 'pt-BR' or lang == 'pt' %} class="active"{% endif %}>PT</a>
    </div>
    <button class="burger" aria-label="{{ t_menu | default('Menü') }}"><span></span><span></span><span></span></button>
  </div>
</nav>

{{ content | safe }}

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-col">
      <span class="meta">Zoe Barossi</span>
      <p>{{ t_footer_desc | default('Triathletin. Berlin. Auf dem Weg nach Nizza, 12. September 2026.') }}</p>
    </div>
    <div class="footer-col">
      <span class="meta">{{ t_nav | default('Navigation') }}</span>
      <ul>
        <li><a href="{{ nav_home | default('/') }}">{{ t_home | default('Home') }}</a></li>
        <li><a href="{{ nav_about }}">{{ t_about | default('Über') }}</a></li>
        <li><a href="{{ nav_partner }}">{{ t_partner | default('Partner') }}</a></li>
        <li><a href="{{ nav_live }}">{{ t_live | default('Live') }}</a></li>
      </ul>
    </div>
    <div class="footer-col">
      <span class="meta">{{ t_follow | default('Folgen') }}</span>
      <ul>
        <li><a href="https://instagram.com/zoebarossi" target="_blank" rel="noopener">Instagram</a></li>
        <li><a href="https://twitch.tv/zoebarossi" target="_blank" rel="noopener">Twitch</a></li>
        <li><a href="https://youtube.com/@zoebarossi" target="_blank" rel="noopener">YouTube</a></li>
      </ul>
    </div>
    <div class="footer-col">
      <span class="meta">{{ t_legal | default('Rechtliches') }}</span>
      <ul>
        <li><a href="{{ nav_impressum }}">{{ t_impressum | default('Impressum') }}</a></li>
        <li><a href="{{ nav_datenschutz }}">{{ t_datenschutz | default('Datenschutz') }}</a></li>
        <li><a href="mailto:sponsoring@zoebarossi.com">{{ t_contact | default('Kontakt') }}</a></li>
      </ul>
    </div>
  </div>
  <div class="footer-bottom">
    <span>© 2026 Zoe Barossi</span>
    <span>Berlin → Nizza</span>
  </div>
</footer>

<script src="{{ '/js/nav.js' | url }}" defer></script>
<script>
(function(){
  var k='zoe-access';
  if(localStorage.getItem(k)==='granted') return;
  var p=prompt('Passwort:');
  if(p==='zoe2026'){localStorage.setItem(k,'granted');}
  else{document.body.innerHTML='<div style="display:flex;align-items:center;justify-content:center;height:100vh;font-family:sans-serif;color:#829cae;background:#0d1b2a"><p>Zugang verweigert.</p></div>';}
})();
</script>
{% block scripts %}{% endblock %}

</body>
</html>
